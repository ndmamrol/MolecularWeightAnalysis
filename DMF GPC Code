DMF SEC/GPC molecular weight analysis using chem_analysis.

This script:
1. Loads raw SEC/GPC chromatogram data from a CSV file.
2. Applies an RI calibration curve based on polymer standards.
3. Performs adaptive polynomial baseline correction.
4. Integrates the selected polymer peak.
5. Prints molecular weight statistics and plots the chromatogram.
"""

import logging
from pathlib import Path

import numpy as np
import pandas as pd
from scipy.interpolate import interp1d

import chem_analysis as chem
import chem_analysis.algorithms.baseline_correction as chem_bc


# Suppress detailed chem_analysis logging output
chem.logger_analysis.setLevel(logging.CRITICAL)


def load_chromatogram(file_path: str | Path) -> pd.DataFrame:
    """Load and clean SEC/GPC chromatogram data from a CSV file."""
    df = pd.read_csv(file_path, header=1, index_col=0)

    # Keep retention time and RI signal columns
    df = df.iloc[:30001, :2]
    df.columns = ["signal"]
    df.index.names = ["retention_time_min"]

    return df.apply(pd.to_numeric, errors="coerce")


def create_ri_calibration() -> chem.Cal:
    """Create RI calibration from retention time and molecular weight standards."""
    retention_times = np.array([22.745, 26.025, 28.517, 30.565])
    molecular_weights = np.array([364000, 49350, 6250, 850])

    interpolation = interp1d(
        retention_times,
        np.log(molecular_weights),
        kind="linear",
        fill_value="extrapolate",
    )

    def calibration_function(retention_time: np.ndarray) -> np.ndarray:
        return np.exp(interpolation(retention_time))

    return chem.Cal(
        calibration_function,
        lb=160,
        ub=1_090_000,
        name="RI calibration",
    )


def analyze_sec_trace(
    df: pd.DataFrame,
    calibration: chem.Cal,
    peak_bounds: tuple[float, float] = (24, 30),
) -> chem.SECSignal:
    """Apply baseline correction, integrate peak, and return SEC signal object."""
    signal = chem.SECSignal(
        ser=df["signal"],
        cal=calibration,
        x_label="retention_time_min",
        y_label="signal",
    )

    signal.pipeline.add(chem_bc.adaptive_polynomial_baseline)
    signal.peak_picking(lb=peak_bounds[0], ub=peak_bounds[1])

    return signal


def main() -> None:
    """Run SEC/GPC molecular weight analysis."""
    file_path = Path(r"E:\kugel\20250904_kugel.csv")
    peak_bounds = (24, 30)

    chromatogram = load_chromatogram(file_path)
    calibration = create_ri_calibration()
    signal = analyze_sec_trace(chromatogram, calibration, peak_bounds)

    signal.stats(num_sig_figs=4)
    signal.plot()


if __name__ == "__main__":
    main()

    
